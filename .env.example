# FunChatBot Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to Git

# Required
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_IDS=123456789,987654321

# Database (default works for local dev; Render uses /data/funchatbot.db)
DATABASE_PATH=./data/funchatbot.db

# Webhook (leave empty for polling mode during development)
WEBHOOK_URL=

# Server port
PORT=8080

# Optional AI integration (leave empty to disable AI chat feature)
AI_API_KEY=

# Safety settings
MAX_REPORT_COUNT=5
RATE_LIMIT_MESSAGES=30
RATE_LIMIT_WINDOW=60
